server {
    listen 80;
    listen [::]:80;
    server_name {{ item.vhost }};

    # For certbot
    location ^~ /.well-known/acme-challenge/ {
        root /var/www/html/;
    }

    return 301 https://$host$request_uri;
}

upstream {{ item.vhost }}-backend {
    least_conn;
{% for backend in item.backends %}
    server {{ backend.address }} fail_timeout=3s max_fails=10 {{ backend.options }}; # only mark a server down if many requests fail (due to error, timeout, denied or invalid_header), and try to recover quickly
{% endfor %}
}

map "$http_user_agent:$http_accept_language:$http_accept" $no_ua_no_browser {
    default 0;
    ::*/* 1;
}

server {
    listen 443 ssl;
    listen 443 quic {{ item.quic_options }};
    listen [::]:443 ssl;
    listen [::]:443 quic {{ item.quic_options }};

    http2 on;

    quic_gso on;
    add_header Alt-Svc 'h3=":443"; ma=21600, h3-29=":443"; ma=21600';

    # Override TLS settings from included file
    ssl_protocols TLSv1.2 TLSv1.3;

    ssl_ecdh_curve X25519:prime256v1:secp384r1;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384:DHE-RSA-CHACHA20-POLY1305;
    ssl_prefer_server_ciphers off;

    # see also ssl_session_ticket_key alternative to stateful session cache
    ssl_session_timeout 1d;
    ssl_session_cache shared:MozSSL:10m;  # about 40000 sessions

    # OCSP stapling
    ssl_stapling on;
    ssl_stapling_verify on;

    server_name {{ item.vhost }};

    ssl_certificate /etc/letsencrypt/live/api.transitous.org/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/api.transitous.org/privkey.pem;

    charset UTF-8;

    error_page 403 /error403.html;
    location = /error403.html {
        root /var/www/html/;
        allow all;
    }

    if ($no_ua_no_browser = "1") {
        return 403 "Empty user-agent header is not allowed. Please review the usage policy: https://transitous.org/api/";
    }

    if ($http_user_agent ~ "^(node|python-requests\/\d+.\d+.\d+)$") {
        return 403 "Generic user-agent headers are not allowed, please set your own. Please review the usage policy: https://transitous.org/api/";
    }

    # IP-addresses that have ignored usage policy, should be blocked and shown an according message
    # deny <ip-address>
    deny 208.113.190.160;  # distanzechilometriche.net/2.0

    # For certbot
    location ^~ /.well-known/acme-challenge/ {
        root /var/www/html/;
    }

    # MOTIS Web Interface
    location / {
        root /opt/motis/ui/;
    }

    proxy_ssl_server_name on;
    proxy_pass_header Server;

    # Proxy and cache tiles
    location /tiles/ {
        proxy_pass http://{{ item.vhost }}-backend/tiles/;

        limit_req zone=api_harmless burst=200 delay=50;

        proxy_connect_timeout       2s;
        proxy_send_timeout          10s;
        proxy_read_timeout          10s;
        send_timeout                60s;

        proxy_cache            motis;
        proxy_cache_valid      200 302 1d;
        proxy_cache_valid      404 1s;
        proxy_cache_use_stale  error timeout invalid_header updating
                                http_500 http_502 http_503 http_504;
        add_header Cache-Control "public, max-age=36000";
    }

    location /mapterhorn/ {
        proxy_pass http://tiles.mapterhorn.com/;

        limit_req zone=api_harmless burst=200 delay=50;

        proxy_set_header "User-Agent" "transitous.org";

        proxy_connect_timeout       2s;
        proxy_send_timeout          60;
        proxy_read_timeout          60;
        send_timeout                60;

        proxy_cache            motis;
        proxy_cache_valid      200 302 1d;
        proxy_cache_valid      404 1s;
        proxy_cache_use_stale  error timeout invalid_header updating
                                http_500 http_502 http_503 http_504;
    }

    # OJP endpoint
    location /ojp20 {
        proxy_pass http://{{ item.vhost }}-backend/ojp20;

        limit_req zone=api burst=20 delay=10;
        
        proxy_connect_timeout       2s;
        proxy_send_timeout          60;
        proxy_read_timeout          120;
        send_timeout                60;
    }

    # Rate limit plan API
    location ~ ^/api/(v1|v2|v3|v4|v5|v6|v7|experimental)/(plan|one-to-all) {
        proxy_pass http://{{ item.vhost }}-backend$uri?$args;

        limit_req zone=api_plan burst=20 delay=10;
        limit_conn api_plan_conn 10;

        proxy_connect_timeout       2s;
        proxy_send_timeout          60;
        proxy_read_timeout          120;
        send_timeout                60;
    }

    # Routes that are basically free for us don't need a rate limit
    location ~ ^/api/(v1|v2|v3|v4|v5|v6|v7|experimental)/(geocode|reverse-geocode|stoptimes|map/stops|map/levels|map/initial|trip|refresh-itinerary) {
        proxy_pass http://{{ item.vhost }}-backend$uri?$args;

        limit_req zone=api_harmless burst=150 delay=20;

        proxy_connect_timeout       2s;
        proxy_send_timeout          10s;
        proxy_read_timeout          10s;
        send_timeout                60s;
    }

    # other endpoints
    location /api/ {
        proxy_pass http://{{ item.vhost }}-backend/api/;

        limit_req zone=api burst=40 delay=15;
        proxy_connect_timeout       2s;
        proxy_send_timeout          60;
        proxy_read_timeout          60;
        send_timeout                60;
    }

    # Source files
    location /gtfs/ {
        proxy_pass http://10.11.1.1:80/;
    }

    location /robots.txt {
        alias /var/www/html/robots.txt;
    }
}
